* text=auto

# 常见源码/配置/文档：统一 LF
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.java text eol=lf
*.kt   text eol=lf
*.xml  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf
*.sql  text eol=lf
*.sh   text eol=lf
*.bat  text eol=crlf
*.cmd  text eol=crlf

# 二进制文件：禁止文本归一化
*.png  -text
*.jpg  -text
*.jpeg -text
*.gif  -text
*.pdf  -text
*.zip  -text
*.jar  -text
*.exe  -text